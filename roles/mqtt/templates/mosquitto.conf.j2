# Mosquitto configuration for Orchestrator
listener {{ mqtt_broker_port }}
protocol mqtt

# Allow anonymous access (change if using authentication)
allow_anonymous true

# Log file
log_dest file /var/log/mosquitto/mosquitto.log
log_type all
log_timestamp true

# Persistence
persistence true
persistence_location /var/lib/mosquitto/

# Max connections
max_connections -1

# Message parameters
max_queued_messages 1000
message_size_limit 0
